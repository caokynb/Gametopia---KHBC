  fadeInOnTrigger: 1
  fadeInDuration: 1
  disappearAfterDialogue: 1
  fadeDuration: 1.5
  poofEffectPrefab: {fileID: 0}
  saveState: 1
  uniqueID: OngBut
  endingType: 0
  dialogueLines:
  - characterName: "B\u1EE5t"
    line: "Con khong nh\u1EA3y l\xEAn \u0111\u01B0\u1EE3c? Ta truy\u1EC1n cho con
      c\xE2u th\u1EA7n ch\xFA n\xE0y: 'Kh\u1EAFc Nh\u1EADp - Kh\u1EAFc Nh\u1EADp'.
      Ch\u1EC9 c\u1EA7n \u0111\u1ECDc l\xEAn, c\xE1c \u0111\u1ED1t tre s\u1EBD t\u1EF1
      \u0111\u1ED9ng gh\xE9p n\u1ED1i th\xE0nh b\u1EC7 \u0111\u1EE1 v\u1EEFng ch\xE3i
      \u0111\u01B0a con l\xEAn cao."
    portrait: {fileID: 0}
  - characterName: 
    line: "Gi\u1EEF v\xE0 k\xE9o [Chu\u1ED9t Tr\xE1i] \u0111\u1EC3 d\u1EF1ng b\u1EC7
      \u0111\u1EE1 b\u1EB1ng tre v\u01B0\u1EE3t qua v\xE1ch \u0111\u1EA5t. (Ch\u1EC9
      ho\u1EA1t \u0111\u1ED9ng trong ch\u1EBF \u0111\u1ED9 Nh\u1EADp - X\xE2y D\u1EF1ng)"
    portrait: {fileID: 0}
