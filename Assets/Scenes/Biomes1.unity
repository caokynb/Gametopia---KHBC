--- !u!114 &1183381734
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1183381732}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3426ec19fa992fe4db85df136c7643eb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  isAutoTrigger: 1
  glowEffect: {fileID: 0}
  fadeInOnTrigger: 1
  fadeInDuration: 1
  disappearAfterDialogue: 1
  fadeDuration: 1.5
  poofEffectPrefab: {fileID: 0}
  saveState: 1
  uniqueID: OngBut
  endingType: 0
  dialogueLines:
  - characterName: "B\u1EE5t"
    line: "Tre kh\xF4ng ch\u1EC9 \u0111\u1EC3 x\xE2y b\u1EC7 \u0111\u1EE1, tre c\xF2n
      l\xE0 v\u0169 kh\xED s\u1EAFc b\xE9n b\u1EA3o v\u1EC7 con! V\u1EABn c\xE2u
      th\u1EA7n ch\xFA \u1EA5y, nh\u01B0ng h\xE3y bi\u1EBFn n\xF3 th\xE0nh m\u1ED9t
      c\xE2y th\u01B0\u01A1ng d\u0169ng m\xE3nh \u0111\u1EC3 ph\xE1 h\u1EE7y nh\u1EEFng
      ch\u01B0\u01A1ng ng\u1EA1i v\u1EADt tr\u01B0\u1EDBc m\u1EB7t. "
    portrait: {fileID: 0}
  - characterName: 
    line: "Nh\u1EA5n [E] \u0111\u1EC3 chuy\u1EC3n sang ch\u1EBF \u0111\u1ED9 KH\u1EAEC.
      Nh\u1EA5n [Chu\u1ED9t Tr\xE1i] \u0111\u1EC3 vung th\u01B0\u01A1ng \u0111\xE2m
      v\u1EE1 b\xF9 nh\xECn r\u01A1m (Ch\u1EC9 ho\u1EA1t \u0111\u1ED9ng trong ch\u1EBF
      \u0111\u1ED9 Kh\u1EAFc - T\u1EA5n C\xF4ng)."
    portrait: {fileID: 0}
