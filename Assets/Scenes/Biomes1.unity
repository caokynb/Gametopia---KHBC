  poofEffectPrefab: {fileID: 0}
  saveState: 1
  uniqueID: OngBut
  endingType: 0
  dialogueLines:
  - characterName: Khoai
    line: "Haha, con th\u1EAFc m\u1EAFc t\u1EA1i sao l\xE3o Ph\xFA \xD4ng b\u1EAFt
      con t\xECm c\xE2y tre c\xF3 100 \u0111\u1ED1t m\xE0 ta l\u1EA1i b\u1EA3o con
      \u0111i ch\u1EB7t 100 \u0111\u1ED1t tre \u0111\xFAng kh\xF4ng?"
    portrait: {fileID: 0}
  - characterName: "B\u1EE5t"
    line: "L\xE3o ph\xFA \xF4ng x\u1EA3o quy\u1EC7t \u0111\xE1nh \u0111\u1ED1 con,
      th\xEC ta c\u0169ng c\xF3 c\xE1ch tr\u1ECB l\u1EA1i h\u1EAFn. 100 \u0111\u1ED1t
      tre r\u1EDDi r\u1EA1c n\xE0y ch\xEDnh l\xE0 ch\xECa kh\xF3a. C\u1EE9 b\xECnh
      t\xE2m, v\xE1c tre l\xEAn vai v\xE0 \u0111i theo ta, ta s\u1EBD ch\u1EC9 cho
      con th\u1EA5y ph\xE9p m\xE0u."
    portrait: {fileID: 0}
  - characterName: 
    line: "D\xF9ng ph\xEDm [A] / [D] \u0111\u1EC3 di chuy\u1EC3n. Nh\u1EA5n [W] /
      [Space] \u0111\u1EC3 nh\u1EA3y."
    portrait: {fileID: 0}
