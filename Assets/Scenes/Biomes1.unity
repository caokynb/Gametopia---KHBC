--- !u!114 &1877487402
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1877487400}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3426ec19fa992fe4db85df136c7643eb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  isAutoTrigger: 1
  glowEffect: {fileID: 0}
  fadeInOnTrigger: 1
  fadeInDuration: 1
  disappearAfterDialogue: 1
  fadeDuration: 1.5
  poofEffectPrefab: {fileID: 0}
  saveState: 1
  uniqueID: OngBut
  endingType: 0
  dialogueLines:
  - characterName: "B\u1EE5t"
    line: "Khoai n\xE0y, th\u1EA7n ch\xFA 'Kh\u1EAFc Nh\u1EADp' m\u1EDBi ch\u1EC9
      l\xE0 b\u01B0\u1EDBc \u0111\u1EA7u. Th\u1EED th\xE1ch th\u1EF1c s\u1EF1 c\u1EE7a
      con l\xE0 mang 100 \u0111\u1ED1t tre n\xE0y v\u01B0\u1EE3t qua m\u1ECDi ki\u1EBFp
      n\u1EA1n \u0111\u1EC3 v\u1EC1 \u0111\u1EBFn l\xE0ng. N\u1EBFu con l\xE0m \u0111\u01B0\u1EE3c,
      ta s\u1EBD ban cho con m\u1ED9t ph\xE9p thu\u1EADt cu\u1ED1i c\xF9ng... \u0110\u1EE7
      \u0111\u1EC3 gi\xFAp con c\xF3 \u0111\u01B0\u1EE3c C\xE2y Tre Tr\u0103m \u0110\u1ED1t
      th\u1EADt s\u1EF1. Gi\u1EDD th\xEC, l\xEAn \u0111\u01B0\u1EDDng b\xECnh an
      nh\xE9 con!"
    portrait: {fileID: 0}
  - characterName: "B\u1EE5t"
    line: "\xC0 ngo\xE0i ra, m\u1ED7i l\u1EA7n con d\xF9ng ph\xE9p, tre s\u1EBD hao
      h\u1EE5t d\u1EA7n. Tr\xEAn \u0111\u01B0\u1EDDng v\u1EC1, h\u1EC5 th\u1EA5y
      mi\u1EBFu th\u1EDD linh thi\xEAng th\u1EBF n\xE0y, h\xE3y v\xE0o th\u1EAFp
      m\u1ED9t n\xE9n nhang th\xE0nh t\xE2m. Ta s\u1EBD ch\u1EE9ng gi\xE1m v\xE0
      tri\u1EC7u h\u1ED3i l\u1EA1i \u0111\u1EE7 100 \u0111\u1ED1t tre cho con"
    portrait: {fileID: 0}
  - characterName: 
    line: "Nh\u1EA7n [F] \u0111\u1EC3 t\u01B0\u01A1ng t\xE1c, t\u1EA1i Mi\xEAu s\u1EBD
      l\xE0 h\xE0nh \u0111\u1ED9ng th\u1EAFp h\u01B0\u01A1ng (H\u1ED3i ph\u1EE5c
      to\xE0n b\u1ED9 100 \u0111\u1ED1t tre v\xE0 L\u01B0u v\u1ECB tr\xED)."
    portrait: {fileID: 0}
