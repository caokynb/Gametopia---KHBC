--- !u!114 &754610117
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 754610113}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3426ec19fa992fe4db85df136c7643eb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  isAutoTrigger: 0
  glowEffect: {fileID: 628714678}
  fadeInOnTrigger: 0
  fadeInDuration: 1
  disappearAfterDialogue: 0
  fadeDuration: 1.5
  poofEffectPrefab: {fileID: 0}
  saveState: 0
  uniqueID: OngBut_01
  endingType: 0
  dialogueLines:
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "Ta l\xE0 Tr\xFAc L\xE2m Ch\xE2n Nh\xE2n. C\u1EA3 \u0111\u1EDDi tu \u0111\u1EA1o,
      ta \u0111\xE3 \u0111\xFAc k\u1EBFt tinh hoa \u0111\u1EA5t tr\u1EDDi th\xE0nh
      hai vi\xEAn Linh Ng\u1ECDc trao cho ng\u01B0\u1EDDi s\u1EDF h\u1EEFu kh\u1EA3
      n\u0103ng theo \u0111i\u1EC3m m\u1EA1nh c\u1EE7a h\u1EAFn. Ng\u1ECDc qu\xFD
      tu\u1EF3 duy\xEAn, ch\u1EC9 trao cho k\u1EBB mang ch\xED l\u1EDBn v\xE0 th\u1EA5u
      hi\u1EC3u l\u1EBD tu\u1EA7n ho\xE0n."
    portrait: {fileID: 0}
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "M\u1ED9t vi\xEAn ta kh\u1EA3m n\u01A1i C\u1ED5 Th\u1EE5, ban s\u1EF1 b\u1EC1n
      b\u1EC9 cho k\u1EBB c\u1EA7n m\u1EABn. Vi\xEAn c\xF2n l\u1EA1i ta c\u1EA5t
      gi\u1EEF ch\u1ED1n Hang S\xE2u, ban b\u01B0\u1EDBc nh\u1EA3y th\u0103ng hoa
      cho k\u1EBB can tr\u01B0\u1EDDng."
    portrait: {fileID: 0}
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "K\u1EBB b\u01B0\u1EDBc \u0111\u1EBFn \u0111\xE2y, h\u1EB3n mang trong
      m\xECnh ch\xED l\u1EDBn. N\u01A1i hang s\xE2u n\xE0y c\u1EA5t gi\u1EEF Linh
      Ng\u1ECDc c\u1EE7a gi\xF3. \u0110\u1EC3 \u0111\xE1 t\u1EF1 m\u1EDF, h\xE3y
      d\xF9ng s\xEDnh l\u1EC5 c\u1EE7a ng\u01B0\u01A1i d\xE2ng l\xEAn ba kim l\u01B0
      theo \u0111\xFAng tu\u1EA7n ho\xE0n c\u1EE7a \u0111\u1EA1o tr\u1EDDi."
    portrait: {fileID: 0}
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "L\u01B0 b\xEAn t\u1EA3: Kh\u1EDFi th\u1EE7y t\u1EEB b\xF9n s\xE2u, v\u01B0\u01A1n
      l\xEAn \u0111\u1ED9c nh\u1EA5t m\u1ED9t m\u1EA7m xanh.\" "
    portrait: {fileID: 0}
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "\"L\u01B0 ch\xEDnh gi\u1EEFa: Th\u1EA5m \u0111\u1EABm s\u01B0\u01A1ng
      mai, h\u1ED9i t\u1EE5 \u0111\u1EE7 linh kh\xED Thi\xEAn - \u0110\u1ECBa - Nh\xE2n
      m\xE0 th\xE0nh v\xF3c d\xE1ng."
    portrait: {fileID: 0}
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "L\u01B0 b\xEAn h\u1EEFu: M\u1EB7c cho gi\xF4ng b\xE3o ng\u1EA3 nghi\xEAng,
      v\u1EABn n\u01B0\u01A1ng theo l\u01B0\u1EE1ng c\u1EF1c \xC2m - D\u01B0\u01A1ng
      m\xE0 kh\xF4ng g\xE3y \u0111\u1ED5."
    portrait: {fileID: 0}
  - characterName: "Ch\u1EEF Tr\xEAn Bia \u0110\xE1"
    line: "Th\u1EA5u hi\u1EC3u l\u1EBD \u0111\u1EDDi, nhang tr\xFAc t\u1EF1 kh\u1EAFc
      t\u1ECFa s\xE1ng."
    portrait: {fileID: 0}
