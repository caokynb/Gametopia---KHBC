  m_Script: {fileID: 11500000, guid: 3426ec19fa992fe4db85df136c7643eb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  isAutoTrigger: 1
  glowEffect: {fileID: 0}
  fadeInOnTrigger: 0
  fadeInDuration: 1
  disappearAfterDialogue: 0
  fadeDuration: 1.5
  poofEffectPrefab: {fileID: 0}
  saveState: 0
  uniqueID: OngBut_01
  endingType: 0
  dialogueLines:
  - characterName: "Gi\u1ECDng l\u1EA1"
    line: "D\u1EA1 th\u01B0a b\u1ED1 v\u1EE3 t\u01B0\u01A1ng lai, s\xEDnh l\u1EC5
      h\xF4m nay con xin bi\u1EBFu th\xEAm nh\xE0 m\xECnh m\u1ED9t s\xE0o ru\u1ED9ng
      t\u1ED1t \u1EDF cu\u1ED1i l\xE0ng. Ch\u1EC9 mong b\u1ED1 ch\u1ECDn ng\xE0y
      l\xE0nh th\xE1ng t\u1ED1t \u0111\u1EC3 con s\u1EDBm r\u01B0\u1EDBc c\xE1i M\xF9i
      v\u1EC1."
    portrait: {fileID: 0}
  - characterName: "Ph\xFA \xD4ng"
    line: "Haha, qu\xFD h\xF3a qu\xE1! G\u1EA3 c\xE1i M\xF9i cho c\u1EADu C\u1EA3
      \u0111\xE2y th\xEC nh\xE0 ta m\u1EDBi m\xF4n \u0111\u0103ng h\u1ED9 \u0111\u1ED1i,
      m\xE1t m\u1EB7t v\u1EDBi d\xE2n l\xE0ng."
    portrait: {fileID: 0}
  - characterName: "C\u1EADu C\u1EA3"
    line: "C\u01A1 m\xE0... th\u1EBF c\xF2n c\xE1i t\xEAn Khoai \u1EDF \u0111\u1EE3
      kia th\xEC sao \u1EA1? Nghe n\xF3i h\u1EAFn x\xE1ch dao v\xE0o r\u1EEBng t\xECm
      tre tr\u0103m \u0111\u1ED1t th\u1EADt \u0111\u1EA5y, kh\xE9o gi\u1EDD n\xE0y..."
    portrait: {fileID: 0}
  - characterName: "Ph\xFA \xD4ng"
    line: "\u1ED0i d\xE0o! C\xE1i th\u1EB1ng b\u1EA7n n\xF4ng kh\u1EDD kh\u1EA1o
      \u1EA5y c\xF3 t\xECm \u0111\u1EBFn ki\u1EBFp sau c\u0169ng ch\u1EB3ng th\u1EA5y!
      Gi\u1EDD n\xE0y ch\u1EAFc \u0111\xE3 l\xE0m m\u1ED3i cho c\u1ECDp v\u1ED3,
      h\u1ED5 tha r\u1ED3i. C\u1EADu C\u1EA3 c\u1EE9 y\xEAn t\xE2m lo chuy\u1EC7n
      h\u1EF7 s\u1EF1 \u0111i!"
    portrait: {fileID: 0}
