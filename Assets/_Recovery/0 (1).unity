--- !u!114 &1747902198
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1747902195}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3426ec19fa992fe4db85df136c7643eb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueTrigger
  isAutoTrigger: 1
  glowEffect: {fileID: 635380676}
  fadeInOnTrigger: 0
  fadeInDuration: 1
  disappearAfterDialogue: 0
  fadeDuration: 1.5
  poofEffectPrefab: {fileID: 0}
  saveState: 0
  uniqueID: OngBut_01
  endingType: 1
  dialogueLines:
  - characterName: Khoai
    line: "Th\u01B0a \xD4ng! Con \u0111\xE3 s\u1ED1ng s\xF3t tr\u1EDF v\u1EC1 r\u1ED3i
      \u0111\xE2y. 100 \u0111\u1ED1t tre t\xF4i \u0111\xE3 mang \u0111\u1EE7, \xF4ng
      h\xE3y gi\u1EEF l\u1EDDi h\u1EE9a g\u1EA3 M\xF9i cho con!"
    portrait: {fileID: 0}
  - characterName: "Ph\xFA \xD4ng"
    line: "M\xE0y... m\xE0y c\xF2n s\u1ED1ng sao? Nh\u01B0ng khoan \u0111\xE3! Ta
      b\u1EA3o m\xE0y t\xECm 'M\u1ED9t c\xE2y tre tr\u0103m \u0111\u1ED1t', ch\u1EE9
      \u0111\xE2u b\u1EA3o m\xE0y mang 100 \u0111\u1ED1t tre c\u1ED9c l\u1ED1c, r\u1EDDi
      r\u1EA1c r\xE1c r\u01B0\u1EDFi th\u1EBF n\xE0y v\u1EC1?"
    portrait: {fileID: 0}
  - characterName: "C\u1EADu C\u1EA3"
    line: "\u0110\xFAng \u0111\u1EA5y! \u0110\xE3 ngh\xE8o ki\u1EBFt x\xE1c l\u1EA1i
      c\xF2n ngu ng\u1ED1c. C\xF3 c\xFAt ngay kh\xF4ng, c\u1EA3n tr\u1EDF vi\u1EC7c
      r\u01B0\u1EDBc d\xE2u c\u1EE7a ta."
    portrait: {fileID: 0}
  - characterName: "Ph\xFA \xD4ng"
    line: "Nghe r\xF5 \u0111\xE2y, nh\xE0 ta kh\xF4ng \u0111\u1EDDi n\xE0o g\u1EA3
      con g\xE1i ng\u1ECDc ng\xE0 cho m\u1ED9t k\u1EBB kh\u1ED1 r\xE1ch \xE1o \xF4m
      nh\u01B0 m\xE0y \u0111\xE2u. Bi\u1EBFn kh\u1ECFi \u0111\xE2y ngay!"
    portrait: {fileID: 0}
  - characterName: Khoai
    line: "Con \u0111\xE3 gi\u1EEF \u0111\xFAng ch\u1EEF t\xEDn, v\u1EA1n d\u1EB7m
      mang s\xEDnh l\u1EC5 v\u1EC1, v\u1EADy m\xE0 \xF4ng l\u1EA1i nu\u1ED1t l\u1EDDi.
      \u0110\u01B0\u1EE3c! \u0110\u1EEBng tr\xE1ch Khoai n\xE0y t\xE0n nh\u1EABn.
      \u0110\u1EC3 t\xF4i cho c\xE1c ng\u01B0\u1EDDi m\u1EDF r\u1ED9ng t\u1EA7m m\u1EAFt!"
    portrait: {fileID: 0}
